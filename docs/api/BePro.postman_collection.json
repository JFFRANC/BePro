						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@bepro.com\",\n    \"password\": \"Admin123!\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
					}
				},
				{
					"name": "6.1 Crear colocación",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.success) {",
									"    pm.collectionVariables.set('placementId', res.data.id);",
									"    pm.test('Colocación creada', () => pm.response.to.have.status(201));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"candidateId\": \"{{candidateId}}\",\n    \"hireDate\": \"2026-03-25T00:00:00Z\",\n    \"guaranteeEndDate\": \"2026-06-25T00:00:00Z\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/placements", "host": ["{{baseUrl}}"], "path": ["placements"] },
						"description": "Requiere que el candidato esté en estado Approved (5)"
					}
				},
				{
					"name": "6.2 Ver colocación",
					"request": {
						"method": "GET",
						"url": { "raw": "{{baseUrl}}/placements/{{placementId}}", "host": ["{{baseUrl}}"], "path": ["placements", "{{placementId}}"] }
					}
				},
				{
					"name": "6.3 Colocaciones por cliente",
					"request": {
						"method": "GET",
						"url": { "raw": "{{baseUrl}}/placements/client/{{clientId}}", "host": ["{{baseUrl}}"], "path": ["placements", "client", "{{clientId}}"] }
					}
				},
				{
					"name": "6.4 Actualizar - Garantía cumplida",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"candidateId\": \"{{candidateId}}\",\n    \"candidateFullName\": \"\",\n    \"hireDate\": \"2026-03-25T00:00:00Z\",\n    \"guaranteeEndDate\": \"2026-06-25T00:00:00Z\",\n    \"guaranteeMet\": true,\n    \"terminationDate\": null,\n    \"freelancerPaymentStatus\": 1,\n    \"freelancerPaymentDate\": \"2026-07-01T00:00:00Z\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/placements/{{placementId}}", "host": ["{{baseUrl}}"], "path": ["placements", "{{placementId}}"] },
						"description": "Marca garantía cumplida y pago al freelancer. PaymentStatus: Paid = 1"
					}
				},
				{
					"name": "6.5 Verificar candidato quedó GuaranteeMet",
					"request": {
						"method": "GET",
						"url": { "raw": "{{baseUrl}}/candidates/{{candidateId}}", "host": ["{{baseUrl}}"], "path": ["candidates", "{{candidateId}}"] }
					}
				}
			]
		}
	]
}
