{
  "name": "@bepro/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:env": "export $(cat ../../apps/api/.dev.vars | xargs) &&",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "export $(cat ../../apps/api/.dev.vars | xargs) && drizzle-kit push",
    "db:studio": "export $(cat ../../apps/api/.dev.vars | xargs) && drizzle-kit studio",
    "db:seed": "export $(cat ../../apps/api/.dev.vars | xargs) && tsx scripts/seed.ts",
    "seed:candidates-10k": "export $(cat ../../apps/api/.dev.vars | xargs) && tsx scripts/seed-10k-candidates.ts",
    "db:apply-rls": "export $(cat ../../apps/api/.dev.vars | xargs) && tsx scripts/apply-rls.ts",
    "db:exec": "export $(cat ../../apps/api/.dev.vars | xargs) && tsx scripts/db-exec.ts",
    "db:query": "export $(cat ../../apps/api/.dev.vars | xargs) && tsx scripts/db-query.ts",
    "db:create-app-worker": "export $(cat ../../apps/api/.dev.vars | xargs) && tsx scripts/create-app-worker.ts",
    "db:reset-admin": "export $(cat ../../apps/api/.dev.vars | xargs) && tsx scripts/reset-admin.ts",
    "migrate:012": "export $(cat ../../apps/api/.dev.vars | xargs) && tsx scripts/012-rename-legacy-formconfig-collisions.ts",
    "migrate:012:dry-run": "export $(cat ../../apps/api/.dev.vars | xargs) && tsx scripts/012-rename-legacy-formconfig-collisions.ts --dry-run",
    "db:setup": "pnpm db:push && pnpm db:apply-rls && pnpm db:seed",
    "db:reset": "pnpm db:push -- --force && pnpm db:apply-rls && pnpm db:seed"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "drizzle-orm": "^0.44.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "ws": "^8.20.0"
  }
}
