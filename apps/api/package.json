{
  "name": "@bepro/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "node --env-file=.dev.vars ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "lint": "echo 'lint: ok'"
  },
  "dependencies": {
    "@bepro/db": "workspace:*",
    "@bepro/shared": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.7.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3",
    "wrangler": "^4.19.1",
    "ws": "^8.20.0"
  }
}
